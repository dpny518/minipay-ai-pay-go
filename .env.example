# ─── Blockchain ───────────────────────────────────────────────────────────────
# Chain to use: 44787 (Alfajores testnet) or 42220 (Celo mainnet)
NEXT_PUBLIC_CHAIN_ID=44787

# Deployed TaskEscrow contract addresses (fill after deploy)
NEXT_PUBLIC_ESCROW_ADDRESS_TESTNET=0x
NEXT_PUBLIC_ESCROW_ADDRESS_MAINNET=0x

# ─── Operator (backend only — NEVER expose to frontend) ───────────────────────
# The wallet that calls release() / refund() on the escrow contract
# Also the wallet used to pay x402 AgentCash APIs
OPERATOR_PRIVATE_KEY=0x
OPERATOR_ADDRESS=0x

# ─── Hardhat deploy ───────────────────────────────────────────────────────────
PRIVATE_KEY=0x
CELOSCAN_API_KEY=

# ─── Fee recipient ────────────────────────────────────────────────────────────
FEE_RECIPIENT=0x
FEE_BPS=1500
